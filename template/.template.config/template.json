{
  "$schema": "http://json.schemastore.org/template",
  "author": "Clean Backend Template",
  "classifications": [ "Web", "API", "Clean Backend" ],
  "identity": "CleanBackend.Template",
  "name": "Clean Backend",
  "shortName": "clean-backend",
  "sourceName": "Product",
  "preferNameDirectory": true,
  "symbols": {},
  "sources": [
    {
      "source": "./",
      "target": "./",
      "exclude": [
        "**/[Bb]in/**",
        "**/[Oo]bj/**",
        ".template.config/**"
      ],
      "copyOnly": [
        "eng/local-feed/*.nupkg",
        "src/Product.Api/packages.lock.json"
      ]
    }
  ]
}
